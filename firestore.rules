rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public read-only access for portfolio, machines, and settings
    match /portfolio/{id} {
      allow read: if true;
      allow write: if false;
    }
    match /machines/{id} {
      allow read: if true;
      allow write: if false;
    }
    match /settings/{id} {
      allow read: if true;
      allow write: if false;
    }
    // Inquiries: no public access
    match /inquiries/{id} {
      allow read, write: if false;
    }
  }
}
